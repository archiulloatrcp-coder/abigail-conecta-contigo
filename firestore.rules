rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isValidMessageCreate() {
      return request.resource.data.keys().hasOnly([
          'fullName',
          'email',
          'phone',
          'message',
          'source',
          'website',
          'elapsedMs',
          'status',
          'isRead',
          'readAt',
          'userAgent',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.fullName is string
        && request.resource.data.fullName.size() > 0
        && request.resource.data.fullName.size() <= 120
        && request.resource.data.email is string
        && request.resource.data.email.size() <= 160
        && request.resource.data.phone is string
        && request.resource.data.phone.size() <= 30
        && request.resource.data.message is string
        && request.resource.data.message.size() > 0
        && request.resource.data.message.size() <= 2000
        && request.resource.data.source == 'landing'
        && request.resource.data.website is string
        && request.resource.data.website == ''
        && (request.resource.data.elapsedMs is int || request.resource.data.elapsedMs is float)
        && request.resource.data.elapsedMs >= 3000
        && request.resource.data.status == 'new'
        && request.resource.data.isRead == false
        && request.resource.data.readAt == null
        && request.resource.data.userAgent is string
        && request.resource.data.userAgent.size() <= 500
        && (request.resource.data.email.size() > 0 || request.resource.data.phone.size() > 0)
        && (request.resource.data.email == '' || request.resource.data.email.matches('^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$'))
        && (request.resource.data.phone == '' || request.resource.data.phone.matches('^\\+?[0-9()\\-\\s]{7,20}$'))
        && request.resource.data.createdAt is timestamp
        && request.resource.data.updatedAt is timestamp;
    }

    // Users
    match /users/{userId} {
      allow read: if request.auth != null
        && (request.auth.uid == userId
          || isAdmin());
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null
        && (request.auth.uid == userId
          || isAdmin());
    }
    // Patients
    match /patients/{patientId} {
      allow read: if request.auth != null
        && (isAdmin()
          || resource.data.userId == request.auth.uid);
      allow write: if request.auth != null && isAdmin();
    }
    // Specialties
    match /specialties/{id} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && isAdmin();
    }
    // Psychologists
    match /psychologists/{id} {
      allow read: if request.auth != null
        && (isAdmin()
          || resource.data.userId == request.auth.uid);
      allow write: if request.auth != null && isAdmin();
    }
    // Client messages
    match /client_messages/{messageId} {
      allow create: if isValidMessageCreate();
      allow read, update, delete: if request.auth != null && isAdmin();
    }
  }
}
